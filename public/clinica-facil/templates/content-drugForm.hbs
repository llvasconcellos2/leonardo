{{> pageHeading title='drugs_drugs' }}

<div class="wrapper wrapper-content animated fadeInRight">
  <div class="row">
    <div class="col-sm-12" id="tablebox">
      <div class="ibox">
        <div class="ibox-title">
          <h5>{{_ 'drugs_drugs'}}
            <small class="m-l-sm">{{_ 'drugs_manage'}}</small>
          </h5>
          <button class="btn btn-sm btn-primary pull-right m-t-n-xs" id="btn-new-drug">
            <strong><i class="fa fa-plus"></i> {{_ 'drugs_new'}}</strong>
          </button>
        </div>
        <div class="ibox-content">
          <form id="drugForm" class="drug-form" novalidate>
            <div class="row">
              <div class="col-sm-6">
                <div class="form-group">
                  <label class="control-label">{{_ 'drugs_name'}} *</label>
                  <input type="text" name="name" id="drug-name" required class="form-control">
                </div>
              </div>
              <div class="col-sm-6">
                <div class="form-group">
                  <label class="control-label">{{_ 'drugs_commercial_name'}}</label>
                  <input type="text" name="commercial_name" class="form-control">
                </div>
              </div>
            </div>
            <div class="row">
              <div class="col-sm-6">
                <div class="form-group">
                  <label class="control-label">{{_ 'drugs_generic_name'}}</label>
                  <input type="text" name="generic_name" class="form-control">
                </div>
              </div>
              <div class="col-sm-6">
                <div class="form-group">
                  <label class="control-label">{{_ 'drugs_popular_pharmacy_name'}}</label>
                  <input type="text" name="popular_pharmacy_name" class="form-control">
                </div>
              </div>
            </div>
            <div class="row">
              <div class="col-sm-12">
                <div class="form-group">
                  <label class="control-label">{{_ 'drugs_special_prescription'}}</label>
                  <div>
                    <label class="radio-inline">
                      <input type="radio" name="special_prescription" value="true"> Sim
                    </label>
                    <label class="radio-inline">
                      <input type="radio" name="special_prescription" value="false" checked> Não
                    </label>
                  </div>
                </div>
              </div>
            </div>
            <div class="form-group">
              <label class="control-label">{{_ 'drugs_search'}}</label>
              <textarea name="search" rows="4" class="form-control"></textarea>
            </div>
            <div class="form-group">
              <label class="control-label">{{_ 'drugs_html'}}</label>
              <textarea name="html" id="drug-html" rows="10" class="form-control"></textarea>
            </div>

            <div id="table-footer" class="ibox-footer">
              <div class="form-group text-right">
                <button type="button" class="btn btn-danger delete-btn" id="drug-delete-btn" style="display:none">
                  <i class="fa fa-trash"></i>
                </button>
                <a href="#/drugs" class="btn btn-white"><i class="fa fa-ban"></i> {{_ 'common_cancel'}}</a>
                <button type="submit" class="btn btn-primary">
                  <i class="fa fa-floppy-o"></i> {{_ 'common_save'}}
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
