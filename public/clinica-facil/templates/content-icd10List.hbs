{{> pageHeading title='common_icd' }}

<div class="wrapper wrapper-content animated fadeInRight">
  <div class="row">
    <div class="col-sm-12">
      <div class="ibox">
        <div class="ibox-content" id="icd10-info-panel" style="display:none;">
          <h5 id="icd10-info-title"></h5>
          <p id="icd10-info-description"></p>
          <dl class="dl-horizontal" style="margin-bottom:0;">
            <dt>{{_ 'icd10_info_publisher'}}</dt><dd id="icd10-info-publisher"></dd>
            <dt>{{_ 'icd10_info_version'}}</dt><dd id="icd10-info-version"></dd>
            <dt>{{_ 'icd10_info_date'}}</dt><dd id="icd10-info-date"></dd>
            <dt>{{_ 'icd10_info_source'}}</dt><dd><a id="icd10-info-source" href="#" target="_blank" rel="noopener"></a></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>
  <div class="row icd10">
    <div class="col-sm-12" id="tablebox">
      <div class="ibox">
        <div class="ibox-title">
          <h5>{{_ 'common_icd'}} <small class="m-l-sm">{{_ 'common_manage_icd'}}</small></h5>
          <button class="btn btn-sm btn-primary pull-right m-t-n-xs new-record" id="new-icd10-btn">
            <strong><i class="fa fa-plus" aria-hidden="true"></i> {{_ 'icd10_new'}}</strong>
          </button>
        </div>
        <div class="ibox-content">
          <div class="table-responsive">
            <table id="icd10-table" class="table table-striped table-bordered table-hover dataTable"></table>
          </div>
        </div>
        <div id="table-footer" class="ibox-footer"></div>
      </div>
    </div>
    <div class="col-sm-0" id="icd10-formbox">
      <div class="ibox">
        <div class="ibox-title">
          <h5>{{_ 'icd10_edit'}}</h5>
        </div>
        <div class="ibox-content">
          <form id="icd10-form" role="form">
            <div class="form-group">
              <label>{{_ 'icd10_code'}}</label>
              <input type="text" name="code" placeholder="{{_ 'icd10_codePlaceholder'}}" class="form-control" required>
            </div>
            <div class="form-group">
              <label>{{_ 'icd10_display'}}</label>
              <input type="text" name="display" placeholder="{{_ 'icd10_displayPlaceholder'}}" class="form-control" required>
            </div>
            <div>
              <button class="btn btn-sm btn-danger" type="button" id="icd10-delete-btn" style="display: none;">
                <i class="fa fa-trash" aria-hidden="true"></i>
              </button>
              <button class="btn btn-sm btn-primary pull-right m-t-n-xs" type="submit">
                <strong><i class="fa fa-floppy-o"></i> {{_ 'common_save'}}</strong>
              </button>
              <button class="btn btn-sm btn-white pull-right m-t-n-xs" type="button" id="icd10-form-cancel">
                <strong><i class="fa fa-ban"></i> {{_ 'common_cancel'}}</strong>
              </button>
            </div>
          </form>
        </div>
        <div class="ibox-footer">&nbsp;</div>
      </div>
    </div>
  </div>
</div>
