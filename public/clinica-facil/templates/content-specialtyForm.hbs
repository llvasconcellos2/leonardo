{{> pageHeading title='specialties_specialties' }}

<div class="wrapper wrapper-content animated fadeInRight">
  <div class="row">
    <div class="col-sm-12" id="tablebox">
      <div class="ibox">
        <div class="ibox-title">
          <h5>{{_ 'specialties_specialties'}}
            <small class="m-l-sm">{{_ 'specialties_create-form-title'}}</small>
          </h5>
          <button class="btn btn-sm btn-primary pull-right m-t-n-xs" id="btn-new-specialty">
            <strong><i class="fa fa-plus"></i> {{_ 'specialties_new'}}</strong>
          </button>
        </div>
        <div class="ibox-content">
          <form id="specialtyForm" class="form-inline specialty-form" novalidate>
            <div class="form-group" id="fg-name">
              <label class="control-label">{{_ 'specialties_specialty'}}</label>
              <input type="text" name="name" id="specialty-name" maxlength="100" required class="form-control" style="min-width:300px">
              <span class="help-block"></span>
            </div>
            <div class="form-group text-right" style="display:block;margin-top:16px">
              <button type="button" class="btn btn-danger delete-btn" id="specialty-delete-btn" style="display:none">
                <i class="fa fa-trash"></i>
              </button>
              <a href="#/specialties" class="btn btn-white"><i class="fa fa-ban"></i> {{_ 'common_cancel'}}</a>
              <button type="submit" class="btn btn-primary">
                <i class="fa fa-floppy-o"></i> {{_ 'common_save'}}
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
