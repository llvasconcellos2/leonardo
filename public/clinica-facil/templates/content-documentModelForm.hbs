{{> pageHeading title='document-models_document-models' }}

<div class="wrapper wrapper-content animated fadeInRight">
  <div class="row">
    <div class="col-sm-12" id="tablebox">
      <div class="ibox">
        <div class="ibox-title">
          <h5>{{_ 'document-models_document-models'}}
            <small class="m-l-sm">{{_ 'document-models_manage'}}</small>
          </h5>
          <button class="btn btn-sm btn-primary pull-right m-t-n-xs" id="btn-new-document-model">
            <strong><i class="fa fa-plus"></i> {{_ 'document-models_new'}}</strong>
          </button>
        </div>
        <div class="ibox-content">
          <form id="documentModelForm" class="document-model-form" novalidate>
            <div class="form-group">
              <label class="control-label">{{_ 'document-models_name'}}</label>
              <input type="text" name="name" id="dm-name" required class="form-control">
            </div>
            <div class="form-group">
              <label class="control-label">{{_ 'document-models_description'}}</label>
              <textarea name="description" id="dm-description" rows="5" required class="form-control"></textarea>
            </div>
            <div class="form-group">
              <label class="control-label">{{_ 'document-models_type'}}</label>
              <select name="type" id="dm-type" required class="form-control chosen-select">
                <option value="">{{_ 'common_firstOption'}}</option>
                <option value="prescription">{{_ 'common_prescription'}}</option>
                <option value="medical_certificate">{{_ 'common_medical-certificate'}}</option>
                <option value="exam_request">{{_ 'common_exam-request'}}</option>
                <option value="prescriptions-anvisa">{{_ 'common_prescriptions-anvisa'}}</option>
              </select>
            </div>
            <div class="form-group">
              <label class="control-label">{{_ 'document-models_document-model'}}</label>
              <textarea name="model" id="dm-model" rows="20" class="form-control"></textarea>
            </div>
            <p>{{{_ 'document-models_help'}}}</p>
            <p>{{{_ 'document-models_help-patient-info'}}}</p>
            <p>{{{_ 'document-models_help-icd10'}}}</p>
            <p>{{{_ 'document-models_help-drug'}}}</p>
          </form>
        </div>
        <div id="table-footer" class="ibox-footer">
          <div class="form-group text-right">
            <button type="button" class="btn btn-danger delete-btn" id="dm-delete-btn" style="display:none">
              <i class="fa fa-trash"></i>
            </button>
            <button type="button" class="btn btn-white cancel" id="dm-cancel-btn">
              <i class="fa fa-ban"></i> {{_ 'common_cancel'}}
            </button>
            <button type="button" class="btn btn-primary" id="dm-save-btn">
              <i class="fa fa-floppy-o"></i> {{_ 'common_save'}}
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
